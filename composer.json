{
  "name": "vbcherepanov/phpfilebroker",
  "description": "RabbitMQ + Kafka + NATS — on your filesystem. Exchanges, streams, consumer groups, priority queues, zero dependencies beyond PSR interfaces.",
  "keywords": [
    "message-broker",
    "message-queue",
    "file-broker",
    "exchanges",
    "streams",
    "consumer-groups",
    "dead-letter-queue",
    "priority-queue",
    "publish-subscribe",
    "event-driven",
    "php84",
    "psr-3",
    "psr-14",
    "zero-dependencies"
  ],
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.4",
    "ext-json": "*",
    "ext-spl": "*",
    "ext-ctype": "*",
    "ext-mbstring": "*",
    "psr/event-dispatcher": "^1.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "FileBroker\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "FileBroker\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/file-broker"
  ],
  "config": {
    "sort-packages": true
  }
}
